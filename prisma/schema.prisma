// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id          String    @id
  shop        String
  state       String
  isOnline    Boolean   @default(false)
  scope       String?
  expires     DateTime?
  accessToken String
  userId      BigInt?
}

model Configuration {
  id             Int      @id @default(autoincrement())
  shop           String   @unique
  customLocation String   @default("allpages")
  animationType  String   @default("snowfall")
  animationCount Int      @default(80)
  animationSize  Int      @default(20)
  updatedAt      DateTime @updatedAt
}
